{
  "name": "@canonbridge/transformer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CanonBridge MVP transformer — JSONata + Ajv, HTTP and optional Kafka.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "fastify": "^5.2.1",
    "jsonata": "^2.0.6",
    "kafkajs": "^2.2.4",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
