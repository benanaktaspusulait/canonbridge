{
  "name": "@canonbridge/transformer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CanonBridge MVP transformer — JSONata + Ajv, HTTP and optional Kafka.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run && npm run test:mapping-fixtures && npm run test:ten-system-smoke",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:mapping-fixtures": "node scripts/validate-mapping-fixtures.mjs",
    "test:ten-system-smoke": "node scripts/validate-ten-system-smoke.mjs",
    "test:schema-compatibility": "node scripts/check-schema-compatibility.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/swagger": "9.4.2",
    "@fastify/swagger-ui": "5.2.1",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "fastify": "^5.2.1",
    "ioredis": "^5.10.1",
    "jsonata": "^2.1.0",
    "kafkajs": "^2.2.4",
    "pg": "^8.20.0",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "@types/ioredis": "^4.28.10",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "3.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "3.2.2"
  }
}
