# CanonBridge Transformer Service Configuration
# Copy this file to .env and update with your actual values

# =============================================================================
# Server Configuration
# =============================================================================
PORT=8080
LOG_LEVEL=info

# =============================================================================
# Security - API Key Authentication
# =============================================================================
# IMPORTANT: Set this in production to protect admin endpoints like /v1/admin/reload
# Generate with: openssl rand -hex 32
API_KEY=CHANGE_ME_your_secure_api_key_here

# CORS Origins (comma-separated, empty = allow all)
CORS_ORIGINS=http://localhost:4200,http://localhost:3000

# =============================================================================
# Mappings
# =============================================================================
MAPPINGS_ROOT=../../../mappings

# =============================================================================
# Kafka Configuration
# =============================================================================
KAFKA_ENABLED=true
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=canonbridge-transformer
KAFKA_FALLBACK_DLQ_TOPIC=canonbridge.dlq

# Kafka Connection Retry
KAFKA_CONNECT_RETRIES=10
KAFKA_CONNECT_RETRY_DELAY_MS=3000

# Kafka SSL/SASL (optional)
KAFKA_SSL_ENABLED=false
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# =============================================================================
# Redis Cache (optional, defaults to in-memory)
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL_SECONDS=3600

# =============================================================================
# Worker Pool (for CPU-intensive transformations)
# =============================================================================
WORKER_POOL_ENABLED=false
WORKER_POOL_SIZE=0  # 0 = auto (CPU count - 1)

# =============================================================================
# Outbox Pattern (for exactly-once delivery)
# =============================================================================
OUTBOX_ENABLED=false
OUTBOX_DATABASE_URL=postgresql://user:pass@localhost:5432/canonbridge_db
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=100
