# CanonBridge production environment template.
# Copy to .env.production on the server and replace every REPLACE_WITH_* value.
# Keep .env.production out of git.

# -----------------------------------------------------------------------------
# Public domains and TLS
# -----------------------------------------------------------------------------
CANONBRIDGE_DOMAIN=canonbridge.io
ACME_EMAIL=admin@canonbridge.io
NEXT_PUBLIC_SITE_URL=https://canonbridge.io
NEXT_PUBLIC_LEAD_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Image/build tag
# -----------------------------------------------------------------------------
CANONBRIDGE_IMAGE_TAG=latest

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
POSTGRES_DB=canonbridge_db
POSTGRES_USER=canonbridge_user
POSTGRES_PASSWORD=REPLACE_WITH_LONG_RANDOM_POSTGRES_PASSWORD

# -----------------------------------------------------------------------------
# Kafka and Redis
# -----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_BROKERS=kafka:29092
KAFKA_RAW_TOPIC=partner.raw.events
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# Mapping Studio API production security
# -----------------------------------------------------------------------------
ENVIRONMENT=production
SECURITY_FAIL_ON_INSECURE_DEFAULTS=true
SECURITY_PRODUCTION_REQUIRES_OIDC=true
SECURITY_REQUIRE_OIDC_CLIENT_SECRET=true
CANONBRIDGE_PRODUCTION_ALLOWS_LOCAL_LOGIN=false

CANONBRIDGE_AUTH_ENABLED=true
CANONBRIDGE_API_KEY_AUTH_ENABLED=true
CANONBRIDGE_BEARER_API_KEY_ENABLED=false
CANONBRIDGE_LOCAL_JWT_ENABLED=false
CANONBRIDGE_LOCAL_LOGIN_ENABLED=false
CANONBRIDGE_PUBLIC_DOCS_ENABLED=false
CANONBRIDGE_API_KEYS=REPLACE_WITH_COMMA_SEPARATED_PRODUCTION_API_KEYS
CANONBRIDGE_CREDENTIAL_ENCRYPTION_KEY=REPLACE_WITH_BASE64_32_BYTE_KEY

OIDC_ENABLED=true
OIDC_SERVER_URL=https://idp.canonbridge.io/realms/canonbridge
OIDC_CLIENT_ID=mapping-studio-api
OIDC_CLIENT_SECRET=REPLACE_WITH_OIDC_CLIENT_SECRET
CORS_ALLOWED_ORIGINS=https://studio.canonbridge.io,https://canonbridge.io,https://www.canonbridge.io

JWT_SECRET_KEY=REPLACE_WITH_LONG_RANDOM_JWT_SECRET_FOR_NON_OIDC_OPERATIONS
JWT_ISSUER=canonbridge
JWT_TTL_SECONDS=28800
HTTP_MAX_BODY_SIZE=10M

# -----------------------------------------------------------------------------
# Mapping Studio UI runtime config
# -----------------------------------------------------------------------------
CANONBRIDGE_API_BASE_URL=https://api.canonbridge.io/api
CANONBRIDGE_WEBSOCKET_URL=wss://api.canonbridge.io/api/notifications/ws
CANONBRIDGE_AUTH_ISSUER=https://idp.canonbridge.io/realms/canonbridge
CANONBRIDGE_AUTH_CLIENT_ID=mapping-studio-ui
CANONBRIDGE_AUTH_REDIRECT_URI=https://studio.canonbridge.io/auth/callback
CANONBRIDGE_TENANT_ID=tenant-acme
CANONBRIDGE_TENANT_NAME=CanonBridge Production
CANONBRIDGE_TRANSFORMER_API_URL=
CANONBRIDGE_ENABLE_DEMO_MODE=false

# -----------------------------------------------------------------------------
# Runtime workers
# -----------------------------------------------------------------------------
RATELIMIT_ENABLED=true
SCHEDULED_POLLER_ENABLED=true
SCHEDULED_POLLER_TICK_SECONDS=60
SCHEDULED_POLLER_DEFAULT_INTERVAL=PT15M
OUTBOX_REPLAY_ENABLED=true
OUTBOX_REPLAY_TICK_SECONDS=30
OUTBOX_REPLAY_BATCH_SIZE=50
OUTBOX_REPLAY_MAX_ATTEMPTS=10

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=REPLACE_WITH_LONG_RANDOM_GRAFANA_PASSWORD

# -----------------------------------------------------------------------------
# Internal mock connector credentials
# Keep these internal; do not publish canonbridge-mock directly.
# -----------------------------------------------------------------------------
PAYFLEX_API_KEY=REPLACE_WITH_INTERNAL_PAYFLEX_DEMO_KEY
SHOPMAX_CLIENT_ID=REPLACE_WITH_INTERNAL_SHOPMAX_CLIENT_ID
SHOPMAX_CLIENT_SECRET=REPLACE_WITH_INTERNAL_SHOPMAX_CLIENT_SECRET
FASTCARGO_USERNAME=REPLACE_WITH_INTERNAL_FASTCARGO_USERNAME
FASTCARGO_PASSWORD=REPLACE_WITH_INTERNAL_FASTCARGO_PASSWORD
