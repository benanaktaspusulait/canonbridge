{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://getcanonbridge.com/schemas/canonical/order-created.v1.schema.json",
  "title": "Canonical Order Created Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId",
    "tenantId",
    "partnerId",
    "eventType",
    "schemaVersion",
    "occurredAt",
    "correlationId",
    "payload"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "minLength": 1
    },
    "tenantId": {
      "type": "string",
      "minLength": 1
    },
    "partnerId": {
      "type": "string",
      "minLength": 1
    },
    "eventType": {
      "const": "CanonicalOrderCreated"
    },
    "schemaVersion": {
      "const": "v1"
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "correlationId": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "orderId",
        "customerName",
        "customerEmail",
        "orderDate",
        "status",
        "currency",
        "lines",
        "totalAmount"
      ],
      "properties": {
        "orderId": {
          "type": "string",
          "minLength": 1
        },
        "customerName": {
          "type": "string",
          "minLength": 1
        },
        "customerEmail": {
          "type": "string",
          "format": "email"
        },
        "orderDate": {
          "type": "string",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "enum": ["ACTIVE", "INACTIVE", "SUSPENDED", "UNKNOWN"]
        },
        "currency": {
          "type": "string",
          "minLength": 3,
          "maxLength": 3
        },
        "lines": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "lineId",
              "productId",
              "quantity",
              "unitPrice",
              "lineTotal"
            ],
            "properties": {
              "lineId": {
                "type": "string",
                "minLength": 1
              },
              "productId": {
                "type": "string",
                "minLength": 1
              },
              "quantity": {
                "type": "integer",
                "minimum": 1
              },
              "unitPrice": {
                "type": "number",
                "minimum": 0
              },
              "lineTotal": {
                "type": "number",
                "minimum": 0
              }
            }
          }
        },
        "totalAmount": {
          "type": "number",
          "minimum": 0
        }
      }
    }
  }
}
