# CanonBridge Environment Configuration
# Copy this file to .env and update with your actual values
# NEVER commit .env to version control!

# =============================================================================
# Database Configuration
# =============================================================================
POSTGRES_DB=canonbridge_db
POSTGRES_USER=canonbridge_user
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_URL=redis://redis:6379

# =============================================================================
# Kafka Configuration
# =============================================================================
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# =============================================================================
# Authentication & Security
# =============================================================================
# API Keys (comma-separated list)
CANONBRIDGE_API_KEYS=CHANGE_ME_dev-api-key,CHANGE_ME_prod-api-key

# Credential Encryption Key (base64-encoded 32-byte key)
# Generate with: openssl rand -base64 32
CANONBRIDGE_CREDENTIAL_ENCRYPTION_KEY=CHANGE_ME_MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=

# Enable/disable authentication
CANONBRIDGE_AUTH_ENABLED=true
CANONBRIDGE_API_KEY_AUTH_ENABLED=true
CANONBRIDGE_BEARER_API_KEY_ENABLED=false
CANONBRIDGE_LOCAL_JWT_ENABLED=true
CANONBRIDGE_LOCAL_LOGIN_ENABLED=true
CANONBRIDGE_PUBLIC_DOCS_ENABLED=false

# Production auth hardening
ENVIRONMENT=development
SECURITY_FAIL_ON_INSECURE_DEFAULTS=true
SECURITY_PRODUCTION_REQUIRES_OIDC=true
SECURITY_REQUIRE_OIDC_CLIENT_SECRET=true
CANONBRIDGE_PRODUCTION_ALLOWS_LOCAL_LOGIN=false

# OIDC/OAuth2 identity provider
OIDC_ENABLED=false
OIDC_SERVER_URL=https://idp.example.com/realms/canonbridge
OIDC_CLIENT_ID=mapping-studio
OIDC_CLIENT_SECRET=CHANGE_ME_IN_PRODUCTION
CORS_ALLOWED_ORIGINS=https://app.example.com

# Local JWT fallback. Use only outside OIDC-only production.
JWT_SECRET_KEY=CHANGE_ME_GENERATE_A_LONG_RANDOM_SECRET
JWT_ISSUER=canonbridge
JWT_TTL_SECONDS=28800

# HTTP body cap. Chunked batch upload keeps individual requests bounded.
HTTP_MAX_BODY_SIZE=10M

# =============================================================================
# Rate Limiting
# =============================================================================
RATELIMIT_ENABLED=true

# =============================================================================
# Runtime Workers
# =============================================================================
SCHEDULED_POLLER_ENABLED=true
SCHEDULED_POLLER_TICK_SECONDS=60
SCHEDULED_POLLER_DEFAULT_INTERVAL=PT15M
OUTBOX_REPLAY_ENABLED=true
OUTBOX_REPLAY_TICK_SECONDS=30
OUTBOX_REPLAY_BATCH_SIZE=50
OUTBOX_REPLAY_MAX_ATTEMPTS=10

# =============================================================================
# Grafana Configuration
# =============================================================================
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_IN_PRODUCTION

# =============================================================================
# Service URLs (for development)
# =============================================================================
DB_URL=postgresql://postgres:5432/canonbridge_db
JDBC_DB_URL=jdbc:postgresql://postgres:5432/canonbridge_db

# =============================================================================
# Website Lead Capture
# =============================================================================
# Build-time website setting. Points static contact form at CRM/Supabase/webhook.
NEXT_PUBLIC_SITE_URL=https://canonbridge.io
NEXT_PUBLIC_LEAD_WEBHOOK_URL=https://example.supabase.co/functions/v1/canonbridge-leads
