        {
          "name": "Mock API - Query Payments with Body",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-API-Key",
                "value": "demo-api-key-12345"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"CUST-12345\",\n  \"status\": \"COMPLETED\",\n  \"dateFrom\": \"2024-01-01\",\n  \"dateTo\": \"2024-12-31\"\n}"
            },
            "url": {
              "raw": "http://localhost:8085/api/payments/query",
              "protocol": "http",
              "host": ["localhost"],
