  "item": [
    {
      "name": "Proxy Endpoints",
      "item": [
        {
          "name": "POST Proxy - Payment Query with Body",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Tenant-Id",
                "value": "{{tenantId}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"partner_format\": \"detailed\",\n  \"customer_id\": \"CUST-12345\"\n}"
            },
            "url": "{{baseUrl}}/api/proxy/{{mappingIdPost}}",
            "description": "POST proxy example:\n1. Accepts request body with partner_format and customer_id\n2. Transforms request body to API format (adds status, converts fields)\n3. Calls external API with POST\n4. Transforms complex response to simple 5-field format\n5. Returns: paymentId, amount, currency, status, customerEmail"
          },
          "response": []
        },
        {
          "name": "GET Proxy - Payment Latest with Query Params",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Tenant-Id",
                "value": "{{tenantId}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/proxy/{{mappingIdGet}}?format=detailed",
              "host": ["{{baseUrl}}"],
              "path": ["api", "proxy", "{{mappingIdGet}}"],
              "query": [
                {
                  "key": "format",
                  "value": "detailed",
                  "description": "Response format: detailed or flat"
                }
              ]
            },
            "description": "GET proxy example:\n1. Accepts query parameters (no request body)\n2. Transforms query params to API query string\n3. Calls external API with GET\n4. Transforms complex response to simple 5-field format\n5. Returns: paymentId, amount, currency, status, customerEmail"
          },
          "response": [
            {
              "name": "Success - Transformed Response",
              "originalRequest": {
                "method": "GET",
                "header": [
                  {
                    "key": "X-Tenant-Id",
                    "value": "tenant-acme"
                  }
                ],
                "url": {
                  "raw": "http://localhost:8082/api/proxy/e87b7f54-0e6a-4606-9c43-61b0891ce2be?format=detailed",
                  "protocol": "http",
                  "host": ["localhost"],
                  "port": "8082",
                  "path": ["api", "proxy", "e87b7f54-0e6a-4606-9c43-61b0891ce2be"],
                  "query": [
                    {
                      "key": "format",
                      "value": "detailed"
                    }
                  ]
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json;charset=UTF-8"
                }
              ],
              "body": "{\n  \"paymentId\": \"PAY-D4271272\",\n  \"amount\": 1250.5,\n  \"currency\": \"EUR\",\n  \"status\": \"COMPLETED\",\n  \"customerEmail\": \"john.doe@example.com\"\n}"
            }
          ]
        },
