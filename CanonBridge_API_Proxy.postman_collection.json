          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transactionId\": \"TRANSACTIONID-001\"\n}"
            },
            "url": "{{mockApiUrl}}/api/payments/query",
