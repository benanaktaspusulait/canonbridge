                ]
              }
            }
          ]
        },
        {
          "name": "2. Kafka mapping metadata in Studio/API",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "X-Tenant-Id",
                "value": "{{tenantId}}"
              }
            ],
            "url": "{{baseUrl}}/api/mapping-drafts/{{shopmaxKafkaMappingId}}",
            "description": "Shows a KAFKA source mapping in Mapping Studio metadata. The live topic demo uses the transformer fixture topic partner.raw.events because that is the active local transformer subscription."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        }
      ]
    },
