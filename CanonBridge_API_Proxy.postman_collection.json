{
  "info": {
    "name": "CanonBridge API Proxy",
    "description": "Test collection for CanonBridge dynamic API proxy system",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8082",
      "type": "string"
    },
    {
      "key": "tenantId",
      "value": "tenant-acme",
      "type": "string"
    },
    {
      "key": "mappingId",
      "value": "b3bb5c80-7966-4014-a2b4-235539f36b1b",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Proxy Endpoints",
      "item": [
        {
          "name": "Execute Mapping Proxy",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Tenant-Id",
                "value": "{{tenantId}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/proxy/{{mappingId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "proxy", "{{mappingId}}"]
            },
            "description": "Execute a mapping as a proxy. This endpoint:\n1. Accepts request in original format\n2. Applies request transformation (if configured)\n3. Calls the target API\n4. Applies response transformation (if configured)\n5. Returns transformed response"
          },
          "response": [
            {
              "name": "Success - Transformed Response",
              "originalRequest": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "X-Tenant-Id",
                    "value": "tenant-acme"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{}"
                },
                "url": {
                  "raw": "http://localhost:8082/api/proxy/b3bb5c80-7966-4014-a2b4-235539f36b1b",
                  "protocol": "http",
                  "host": ["localhost"],
                  "port": "8082",
                  "path": ["api", "proxy", "b3bb5c80-7966-4014-a2b4-235539f36b1b"]
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json;charset=UTF-8"
                }
              ],
              "body": "{\n  \"paymentId\": \"PAY-56648FAD\",\n  \"amount\": 1250.5,\n  \"currency\": \"EUR\",\n  \"status\": \"COMPLETED\",\n  \"customerEmail\": \"john.doe@example.com\"\n}"
            }
          ]
        },
        {
          "name": "Get Mapping Proxy Info",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Tenant-Id",
                "value": "{{tenantId}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/proxy/{{mappingId}}/info",
              "host": ["{{baseUrl}}"],
              "path": ["api", "proxy", "{{mappingId}}", "info"]
            },
            "description": "Get information about a mapping proxy endpoint"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Direct Mock API (for comparison)",
      "item": [
        {
          "name": "Mock API - Get Latest Payment",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "demo-api-key-12345"
              }
            ],
            "url": {
              "raw": "http://localhost:8085/api/payments/latest",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8085",
              "path": ["api", "payments", "latest"]
            },
            "description": "Direct call to mock API (without proxy) for comparison"
          },
          "response": []
        }
      ]
    }
  ]
}
