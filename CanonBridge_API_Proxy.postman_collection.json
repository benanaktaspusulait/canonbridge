{
  "info": {
    "_postman_id": "7f7f9a8e-2f1e-4c99-9c9d-6f0c0d2fd7b1",
    "name": "CanonBridge API Proxy",
    "description": "Test collection for CanonBridge dynamic API proxy system",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8082",
      "type": "string"
    },
    {
      "key": "tenantId",
      "value": "tenant-acme",
      "type": "string"
    },
    {
      "key": "mappingId",
      "value": "b3bb5c80-7966-4014-a2b4-235539f36b1b",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Proxy Endpoints",
      "item": [
        {
          "name": "Execute Mapping Proxy - Detailed Format",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Tenant-Id",
                "value": "{{tenantId}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"partner_format\": \"detailed\",\n  \"customer_id\": \"CUST-12345\",\n  \"request_id\": \"REQ-001\"\n}"
            },
            "url": "{{baseUrl}}/api/proxy/{{mappingId}}",
            "description": "Execute a mapping as a proxy with detailed format request. This endpoint:\n1. Accepts request in original format (partner's old format)\n2. Applies request transformation (partner_format -> API query params)\n3. Calls the target API (mock payment API)\n4. Applies response transformation (complex payment object -> simple 5 fields)\n5. Returns transformed response in partner's expected format"
          },
          "response": [
            {
              "name": "Success - Transformed Response",
              "originalRequest": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "X-Tenant-Id",
                    "value": "tenant-acme"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"partner_format\": \"detailed\",\n  \"customer_id\": \"CUST-12345\",\n  \"request_id\": \"REQ-001\"\n}"
                },
                "url": {
                  "raw": "http://localhost:8082/api/proxy/b3bb5c80-7966-4014-a2b4-235539f36b1b",
                  "protocol": "http",
                  "host": ["localhost"],
                  "port": "8082",
                  "path": ["api", "proxy", "b3bb5c80-7966-4014-a2b4-235539f36b1b"]
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json;charset=UTF-8"
                }
              ],
              "body": "{\n  \"paymentId\": \"PAY-56648FAD\",\n  \"amount\": 1250.5,\n  \"currency\": \"EUR\",\n  \"status\": \"COMPLETED\",\n  \"customerEmail\": \"john.doe@example.com\"\n}"
            }
          ]
        },
        {
          "name": "Execute Mapping Proxy - Flat Format",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Tenant-Id",
                "value": "{{tenantId}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"partner_format\": \"flat\",\n  \"customer_id\": \"CUST-67890\",\n  \"request_id\": \"REQ-002\"\n}"
            },
            "url": "{{baseUrl}}/api/proxy/{{mappingId}}",
            "description": "Same proxy endpoint but with flat format request to show different request transformation"
          },
          "response": []
        },
        {
          "name": "Execute Mapping Proxy - Invalid Format (Validation Error)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Tenant-Id",
                "value": "{{tenantId}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"partner_format\": \"invalid_format\",\n  \"customer_id\": \"CUST-99999\"\n}"
            },
            "url": "{{baseUrl}}/api/proxy/{{mappingId}}",
            "description": "Test validation - should fail because partner_format must be 'flat' or 'detailed'"
          },
          "response": []
        },
        {
          "name": "Get Mapping Proxy Info",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Tenant-Id",
                "value": "{{tenantId}}"
              }
            ],
            "url": "{{baseUrl}}/api/proxy/{{mappingId}}/info",
            "description": "Get information about a mapping proxy endpoint"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Direct Mock API (for comparison)",
      "item": [
        {
          "name": "Mock API - Get Latest Payment (Detailed)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "demo-api-key-12345"
              }
            ],
            "url": {
              "raw": "http://localhost:8085/api/payments/latest?format=detailed",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8085",
              "path": ["api", "payments", "latest"],
              "query": [
                {
                  "key": "format",
                  "value": "detailed"
                }
              ]
            },
            "description": "Direct call to mock API with detailed format (without proxy) for comparison. Returns full payment object with nested structures."
          },
          "response": []
