  "item": [
    {
      "name": "00 - Login and Opening Scene",
      "description": "Start here in the actual demo. Login proves the browser-facing Studio route and stores authToken for the rest of the collection.",
      "item": [
        {
          "name": "Login as CanonBridge Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{studioUrl}}/api/auth/login",
            "description": "Uses the UI nginx /api proxy, proving the browser-facing route can reach the API.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@canonbridge.io\",\n  \"password\": \"demo123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login returns JWT token', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.token, 'token').to.be.a('string').and.not.empty;",
                  "  pm.expect(json.user.email).to.eql('admin@canonbridge.io');",
                  "  pm.collectionVariables.set('authToken', json.token);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Current user",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": "{{studioUrl}}/api/auth/me",
            "description": "Verifies the JWT stored by the login request."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "01 - REST API Mapping Story",
      "description": "Main REST story: raw external response first, then external auth details, request mapping, response mapping, and before/after proxy output.",
      "item": [
        {
          "name": "1. RAW REST response before CanonBridge mapping",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{mockBearerToken}}"
              }
            ],
            "url": "{{mockApiUrl}}/api/inventorypro/items/SKU-1001",
            "description": "Show this first. This is the external REST system response before CanonBridge changes anything. Point out nested warehouse fields and partner-specific field names."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('mock returns raw nested inventory payload', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.sku).to.eql('SKU-1001');",
                  "  pm.expect(json.warehouse).to.be.an('object');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "2. REST auth detail example - PayFlex API key",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{mockApiKey}}"
              }
            ],
            "url": "{{mockApiUrl}}/api/payments/latest",
            "description": "Use this to show a concrete auth detail: PayFlex expects X-API-Key. This is separate from the InventoryPro bearer-token example, proving CanonBridge can model different auth schemes."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('PayFlex mock returns payment payload', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.payment).to.be.an('object');",
                  "  pm.expect(json.payment.id).to.exist;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "3. Mapping metadata - source type, request config, response rules",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "X-Tenant-Id",
                "value": "{{tenantId}}"
              }
            ],
            "url": "{{baseUrl}}/api/mapping-drafts",
            "description": "Use this together with Studio. Filter or search in the response for InventoryPro Stock Snapshot Mapping. Show source_type=REST_API, source_config for request details, and mapping/generated JSONata fields for response mapping."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "4. InventoryPro mapping detail - request and response mapping source",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "X-Tenant-Id",
                "value": "{{tenantId}}"
              }
            ],
            "url": "{{baseUrl}}/api/mapping-drafts/{{inventoryMappingId}}",
            "description": "Shows the exact mapping record used by the proxy request. In the UI, this corresponds to request mapping and response mapping details."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('mapping detail loaded', function () { pm.response.to.have.status(200); });",
                  "pm.test('mapping is REST_API', function () { pm.expect(pm.response.json().source_type || pm.response.json().sourceType).to.match(/REST_API|REST API/i); });"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "5. CANONBRIDGE PROXY before Studio response-mapping edit",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "X-Tenant-Id",
                "value": "{{tenantId}}"
              }
            ],
            "url": "{{baseUrl}}/api/proxy/{{inventoryMappingId}}",
            "description": "Run after showing request/response mapping in Studio. This is the canonical response before the live response-mapping change."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('proxy returns canonical inventory snapshot', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.stockItemId).to.eql('SKU-1001');",
                  "  pm.expect(json.warehouseCity).to.eql('London');",
                  "  pm.expect(json.availableQuantity).to.be.a('number');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "6. CANONBRIDGE PROXY after Studio response-mapping edit",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "X-Tenant-Id",
                "value": "{{tenantId}}"
              }
            ],
            "url": "{{baseUrl}}/api/proxy/{{inventoryMappingId}}",
            "description": "Rerun this after changing the response mapping in Studio. The URL is intentionally the same; the point is that mapping configuration changes the returned response shape without changing client integration code."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('proxy returns canonical inventory snapshot', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.stockItemId).to.eql('SKU-1001');",
                  "  pm.expect(json.warehouseCity).to.eql('London');",
                  "  pm.expect(json.availableQuantity).to.be.a('number');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "CANONBRIDGE PROXY - CloudBill invoice canonical view",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "X-Tenant-Id",
                "value": "{{tenantId}}"
              }
            ],
            "url": "{{baseUrl}}/api/proxy/{{cloudBillMappingId}}",
            "description": "Second REST proxy example for a billing/invoice source."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02 - Kafka Message Story",
      "description": "After the REST story, show that the same canonicalization idea works for streaming events. Start with HTTP preview in Postman, then use terminal/Kafka UI for live topic proof.",
      "item": [
        {
          "name": "1. Preview raw Kafka order event -> canonical order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{transformerUrl}}/v1/transform",
            "description": "Same payload used in the Kafka terminal demo. It proves the Acme OrderCreated payload maps to CanonicalOrderCreated with two active lines and totalAmount 250.5.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"evt-postman-http-001\",\n  \"tenantId\": \"tenant-demo\",\n  \"partnerId\": \"acme-marketplace\",\n  \"eventType\": \"OrderCreated\",\n  \"schemaVersion\": \"v1\",\n  \"occurredAt\": \"2026-06-18T14:15:00.000Z\",\n  \"correlationId\": \"corr-postman-http-001\",\n  \"payload\": {\n    \"order_header\": {\n      \"order_id\": \"ORD-POSTMAN-HTTP-001\",\n      \"order_date\": \"2026-06-18\",\n      \"status\": \"A\",\n      \"currency\": \"TRY\"\n    },\n    \"customer\": {\n      \"full_name\": \"  Ada Lovelace  \",\n      \"email\": \"\"\n    },\n    \"items\": [\n      {\n        \"item_id\": \"L1\",\n        \"product_code\": \"P100\",\n        \"qty\": \"2\",\n        \"price\": \"100.00\",\n        \"status\": \"ACTIVE\",\n        \"created_at\": \"2026-06-18T14:16:00.000Z\"\n      },\n      {\n        \"item_id\": \"L2\",\n        \"product_code\": \"P200\",\n        \"qty\": \"1\",\n        \"price\": \"50.50\",\n        \"status\": \"ACTIVE\",\n        \"created_at\": \"2026-06-18T14:17:00.000Z\"\n      },\n      {\n        \"item_id\": \"L3\",\n        \"product_code\": \"P999\",\n        \"qty\": \"5\",\n        \"price\": \"1.00\",\n        \"status\": \"CANCELLED\",\n        \"created_at\": \"2026-06-18T14:18:00.000Z\"\n      }\n    ]\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('transformer returns canonical order', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.canonical.eventType).to.eql('CanonicalOrderCreated');",
                  "  pm.expect(json.canonical.payload.orderId).to.eql('ORD-POSTMAN-HTTP-001');",
                  "  pm.expect(json.canonical.payload.lines).to.have.length(2);",
                  "  pm.expect(json.canonical.payload.totalAmount).to.eql(250.5);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "3. Open Kafka UI topics",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{kafkaUiUrl}}",
            "description": "Open Kafka UI and inspect topics: partner.raw.events, canonical.events, usage.events, transformation.dlq."
