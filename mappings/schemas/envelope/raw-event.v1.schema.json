{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://getcanonbridge.com/schemas/envelope/raw-event.v1.schema.json",
  "title": "CanonBridge Raw Event Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId",
    "tenantId",
    "partnerId",
    "eventType",
    "schemaVersion",
    "occurredAt",
    "correlationId",
    "payload"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "minLength": 1
    },
    "tenantId": {
      "type": "string",
      "minLength": 1
    },
    "partnerId": {
      "type": "string",
      "minLength": 1
    },
    "eventType": {
      "type": "string",
      "minLength": 1
    },
    "schemaVersion": {
      "type": "string",
      "pattern": "^v[0-9]+$"
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "correlationId": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "type": "object"
    }
  }
}
