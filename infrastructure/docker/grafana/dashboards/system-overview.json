{
  "title": "ETL Solutions - System Overview",
  "tags": [
    "etl-solutions",
    "system",
    "overview"
  ],
  "timezone": "browser",
  "schemaVersion": 16,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Service Status",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "up{job=~\"transformer|business-service|frontend\"}",
          "legendFormat": "{{job}}"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "value": "0",
              "text": "Down",
              "color": "red"
            },
            {
              "type": "value",
              "value": "1",
              "text": "Up",
              "color": "green"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "red"
              },
              {
                "value": 1,
                "color": "green"
              }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "CPU Usage",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{namespace=\"etl-solutions\"}[5m]) * 100",
          "legendFormat": "{{pod}}"
        }
      ],
      "yaxes": [
        {
          "format": "percent",
          "label": "CPU %"
        },
        {
          "format": "short"
        }
      ]
    },
    {
      "id": 3,
      "title": "Memory Usage",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{namespace=\"etl-solutions\"} / 1024 / 1024 / 1024",
          "legendFormat": "{{pod}}"
        }
      ],
      "yaxes": [
        {
          "format": "decgbytes",
          "label": "Memory (GB)"
        },
        {
          "format": "short"
        }
      ]
    },
    {
      "id": 4,
      "title": "Request Rate",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "expr": "rate(http_requests_total[5m])",
          "legendFormat": "{{job}} - {{method}} {{path}}"
        }
      ],
      "yaxes": [
        {
          "format": "reqps",
          "label": "Requests/sec"
        },
        {
          "format": "short"
        }
      ]
    },
    {
      "id": 5,
      "title": "Error Rate",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "targets": [
        {
          "expr": "rate(http_requests_total{status=~\"5..\"}[5m])",
          "legendFormat": "{{job}} - {{status}}"
        }
      ],
      "yaxes": [
        {
          "format": "reqps",
          "label": "Errors/sec"
        },
        {
          "format": "short"
        }
      ]
    }
  ],
  "uid": "system-overview"
}