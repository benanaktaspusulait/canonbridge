{
  "uid": "proxy-performance",
  "title": "CanonBridge - Proxy Performance",
  "tags": [
    "canonbridge",
    "proxy",
    "performance"
  ],
  "timezone": "browser",
  "schemaVersion": 16,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Proxy Request Rate",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "rate(proxy_requests_total[5m])",
          "legendFormat": "{{mapping_id}} - {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Proxy Success Rate",
      "type": "gauge",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(rate(proxy_requests_total{status=\"success\"}[5m])) / sum(rate(proxy_requests_total[5m])) * 100",
          "legendFormat": "Success %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "red"
              },
              {
                "value": 90,
                "color": "yellow"
              },
              {
                "value": 99,
                "color": "green"
              }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Total Requests",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(proxy_requests_total{status=\"success\"})",
          "legendFormat": "Success"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Total Errors",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 18,
        "y": 4
      },
      "targets": [
        {
          "expr": "sum(proxy_requests_total{status=\"error\"})",
          "legendFormat": "Errors"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Request Duration (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "proxy_request_duration_seconds{quantile=\"0.5\"}",
          "legendFormat": "p50 - {{mapping_id}}"
        },
        {
          "expr": "proxy_request_duration_seconds{quantile=\"0.95\"}",
          "legendFormat": "p95 - {{mapping_id}}"
        },
        {
          "expr": "proxy_request_duration_seconds{quantile=\"0.99\"}",
          "legendFormat": "p99 - {{mapping_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 5
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Error Rate by Mapping",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "rate(proxy_errors_total[5m])",
          "legendFormat": "{{mapping_id}} - {{error_stage}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80
          },
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          }
        }
      }
    },
    {
      "id": 7,
      "title": "HTTP Server Requests by Status",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{uri=~\"/api/proxy.*\"}[5m])",
          "legendFormat": "{{method}} {{uri}} - {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 8,
      "title": "HTTP Server Latency (Proxy Endpoints)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "expr": "http_server_requests_seconds_max{uri=~\"/api/proxy.*\"}",
          "legendFormat": "max - {{method}} {{status}}"
        },
        {
          "expr": "rate(http_server_requests_seconds_sum{uri=~\"/api/proxy.*\"}[5m]) / rate(http_server_requests_seconds_count{uri=~\"/api/proxy.*\"}[5m])",
          "legendFormat": "avg - {{method}} {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 5
          }
        }
      }
    },
    {
      "id": 9,
      "title": "Service Up/Down",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "targets": [
        {
          "expr": "up{job=~\"mapping-studio-api|transformer\"}",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              }
            }
          ]
        }
      }
    }
  ]
}