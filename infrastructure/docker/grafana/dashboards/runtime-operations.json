{
  "uid": "runtime-operations",
  "title": "CanonBridge - Runtime Operations",
  "tags": [
    "canonbridge",
    "runtime",
    "operations"
  ],
  "timezone": "browser",
  "schemaVersion": 16,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Outbox Publish / Replay Failures",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "rate(canonbridge_outbox_publish_failure_total[5m])",
          "legendFormat": "publish failures"
        },
        {
          "expr": "rate(canonbridge_outbox_replay_failure_total[5m])",
          "legendFormat": "replay failures"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Outbox Success",
      "type": "stat",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(increase(canonbridge_outbox_publish_success_total[1h]))",
          "legendFormat": "publish"
        },
        {
          "expr": "sum(increase(canonbridge_outbox_replay_success_total[1h]))",
          "legendFormat": "replay"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Batch Jobs by Status",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum by (status) (increase(canonbridge_batch_jobs_completed_total[5m]))",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Batch Rows Processed",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum by (result) (increase(canonbridge_batch_rows_processed_total[5m]))",
          "legendFormat": "{{result}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Scheduled API Runs",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "sum by (result) (increase(canonbridge_scheduled_runs_completed_total[5m]))",
          "legendFormat": "{{result}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Scheduled API Failure Ratio",
      "type": "gauge",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "expr": "sum(increase(canonbridge_scheduled_runs_completed_total{result=\"failure\"}[1h])) / clamp_min(sum(increase(canonbridge_scheduled_runs_completed_total[1h])), 1) * 100",
          "legendFormat": "failure %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 5,
                "color": "yellow"
              },
              {
                "value": 20,
                "color": "red"
              }
            ]
          }
        }
      }
    }
  ]
}
